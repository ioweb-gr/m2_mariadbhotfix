<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Magento\Framework\DB\Adapter\SqlVersionProvider">
        <arguments>
            <argument name="supportedVersionPatterns" xsi:type="array">
                <item name="MariaDB-10x" xsi:type="string">^10\.\d+\.</item>
                <item name="MariaDB-11x" xsi:type="string">^11\.\d+\.</item>
            </argument>
        </arguments>
    </type>
</config>
